# Copy to .env and adjust. Variables are substituted by Docker Compose (see docker-compose.yml).

# Hamachi / tunnel IPv4 advertised to clients for image server URLs (optional; has compose default).
HAMACHI_IP=127.0.0.1

# First-time market seeding inside the server container (TRUE/FALSE).
SEED_MARKET=TRUE
SEED_SATURATION=80
SEED_REGIONS=Derelik,The Citadel,The Forge,Essence,Domain,Kor-Azor,Metropolis,Sinq Laison

# Set TRUE to run eve-server under gdb inside the container (dev only).
RUN_GDB=FALSE
